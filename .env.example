ENVIRONMENT=development

POSTGRES_DB=trading_dev
POSTGRES_USER=trading
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
POSTGRES_BACKUP_DIR=backups

# Optional bind-mounted persistence. Used only with docker-compose.storage.yml.
# Set an absolute path on a stable Linux filesystem, for example /mnt/trading-data.
TRADING_DATA_ROOT=/mnt/trading-data
# Read-only choices exposed only to super_admin. Format: id=/absolute/path,id2=/path
STORAGE_LOCATION_ALLOWLIST=test_storage=/home/zykid/trading-storage-test

REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg://trading:change-me@postgres:5432/trading_dev
REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.2.42:3000

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

JWT_SECRET_KEY=change-me-use-a-long-random-value
SECRET_ENCRYPTION_KEY=change-me-use-a-32-byte-key

# Phase 3 testnet preparation. Keep disabled unless explicitly testing read-only adapters.
TESTNET_ADAPTERS_ENABLED=false
BINANCE_TESTNET_REST_BASE_URL=https://testnet.binance.vision
BYBIT_TESTNET_REST_BASE_URL=https://api-testnet.bybit.com
OKX_DEMO_REST_BASE_URL=https://www.okx.com
