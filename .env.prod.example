ENVIRONMENT=production

POSTGRES_DB=trading_prod
POSTGRES_USER=trading_prod
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_BACKUP_DIR=/srv/trading/backups

DATABASE_URL=postgresql+psycopg://trading_prod:replace-with-long-random-password@postgres:5432/trading_prod
REDIS_URL=redis://redis:6379/0

PUBLIC_DOMAIN=replace-with-your-domain.example
CADDY_ACME_EMAIL=admin@replace-with-your-domain.example
HTTP_PORT=80
HTTPS_PORT=443
NEXT_PUBLIC_API_BASE_URL=https://replace-with-your-domain.example

DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=10

PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-long-random-grafana-password

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=replace-with-smtp-password
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=ops@example.com
WEBHOOK_ALERTS_ENABLED=false
ALERT_WEBHOOK_URL=https://alerts.example.com/webhook
ALERT_WEBHOOK_SECRET=replace-with-webhook-secret

JWT_SECRET_KEY=replace-with-long-random-secret
SECRET_ENCRYPTION_KEY=replace-with-32-byte-encryption-key

# Production must stay disabled until a separately approved real-trading phase.
TESTNET_ADAPTERS_ENABLED=false
