ENVIRONMENT=production

POSTGRES_DB=trading_prod
POSTGRES_USER=trading_prod
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_BACKUP_DIR=/srv/trading/backups

DATABASE_URL=postgresql+psycopg://trading_prod:replace-with-long-random-password@postgres:5432/trading_prod
REDIS_URL=redis://redis:6379/0

FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=https://replace-with-your-domain.example

DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=10

JWT_SECRET_KEY=replace-with-long-random-secret
SECRET_ENCRYPTION_KEY=replace-with-32-byte-encryption-key

# Production must stay disabled until a separately approved real-trading phase.
TESTNET_ADAPTERS_ENABLED=false
